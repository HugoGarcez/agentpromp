generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id               String                @id @default(uuid())
  name             String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  prompIdentity    String?
  prompToken       String?
  prompUuid        String?
  agents           AgentConfig[]         @relation("CompanyAgents")
  appointments     Appointment[]
  appointmentTypes AppointmentType[]
  googleConfig     GoogleCalendarConfig?
  prompChannels    PrompChannel[]
  specialists      Specialist[]
  tagTriggers      TagTrigger[]
  users            User[]
  xmlCatalogSources XmlCatalogSource[]
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  role              String             @default("USER")
  companyId         String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  resetToken        String?
  resetTokenExpires DateTime?
  notificationsRead NotificationRead[]
  company           Company            @relation(fields: [companyId], references: [id])
}

model AgentConfig {
  id                String          @id @default(uuid())
  companyId         String
  name              String          @default("Agente Principal")
  systemPrompt      String?
  persona           String?
  integrations      String?
  products          String?
  categories        String?
  knowledgeBase     String?
  prompIdentity     String?
  prompConnectionId String?
  prompUuid         String?
  prompToken        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  followUpConfig    String?
  catalogConfig     String?
  transferConfig    String?
  company           Company         @relation("CompanyAgents", fields: [companyId], references: [id])
  history           PromptHistory[]
  prompChannels     PrompChannel[]  @relation("AgentConfigToPrompChannel")
}

model PrompChannel {
  id                String        @id @default(uuid())
  companyId         String
  name              String
  prompIdentity     String
  prompConnectionId String
  prompUuid         String
  prompToken        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents            AgentConfig[] @relation("AgentConfigToPrompChannel")

  @@unique([companyId, prompUuid])
}

model ContactState {
  id           String    @id @default(uuid())
  companyId    String
  remoteJid    String
  lastOutbound DateTime?
  nextFollowUp DateTime?
  attemptIndex Int       @default(0)
  isActive     Boolean   @default(false)
  metadata     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([companyId, remoteJid])
}

model PromptHistory {
  id            String      @id @default(uuid())
  agentConfigId String
  systemPrompt  String?
  createdAt     DateTime    @default(now())
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)
}

model TagTrigger {
  id               String   @id @default(uuid())
  companyId        String
  tagId            Int
  tagName          String
  triggerCondition String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
}

model TestMessage {
  id        String   @id @default(uuid())
  companyId String
  sender    String
  text      String
  sessionId String?
  owner     String?
  metadata  String?
  createdAt DateTime @default(now())
}

model GlobalConfig {
  id                       String   @id @default(uuid())
  openaiKey                String?
  geminiKey                String?
  elevenLabsKey            String?
  elevenLabsVoiceId        String?
  googleClientId           String?
  googleClientSecret       String?
  googleRedirectUri        String?
  googleMapsApiKey         String?
  googlePlacesSearchRadius Int?     @default(5000)
  updatedAt                DateTime @updatedAt
}

model ProductSource {
  id          String    @id @default(uuid())
  companyId   String
  type        String
  url         String?
  fileName    String?
  fileContent String?
  frequency   String
  lastRun     DateTime?
  nextRun     DateTime?
  status      String    @default("active")
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model XmlCatalogSource {
  id              String    @id @default(uuid())
  companyId       String
  name            String
  xmlUrl          String
  fieldMapping    String    // JSON com mapeamento de campos
  refreshMinutes  Int       @default(60)
  enabled         Boolean   @default(true)
  lastSyncAt      DateTime?
  lastSyncStatus  String?   // "ok" | "error"
  lastSyncMessage String?
  productCount    Int       @default(0)
  products        String?   // JSON com a lista de produtos deste catálogo
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model GoogleCalendarConfig {
  id                String    @id @default(uuid())
  companyId         String    @unique
  accessToken       String?
  refreshToken      String?
  tokenExpiry       DateTime?
  primaryCalendarId String?
  timezone          String    @default("America/Sao_Paulo")
  officeHours       String?
  reminderBefore    Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Specialist {
  id               String            @id @default(uuid())
  companyId        String
  name             String
  phone            String?
  email            String?
  calendarId       String?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  appointments     Appointment[]
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appointmentTypes AppointmentType[] @relation("AppointmentTypeToSpecialist")
}

model AppointmentType {
  id           String        @id @default(uuid())
  companyId    String
  name         String
  description  String?
  duration     Int           @default(30)
  color        String?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  specialists  Specialist[]  @relation("AppointmentTypeToSpecialist")
}

model Appointment {
  id            String           @id @default(uuid())
  companyId     String
  googleEventId String?          @unique
  customerId    String?
  customerName  String
  customerPhone String
  specialistId  String?
  typeId        String?
  startTime     DateTime
  endTime       DateTime
  status        String           @default("CONFIRMED")
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  type          AppointmentType? @relation(fields: [typeId], references: [id])
  specialist    Specialist?      @relation(fields: [specialistId], references: [id])
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String             @id @default(uuid())
  title     String
  content   String
  type      String             @default("INFO")
  status    String             @default("DRAFT")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  readBy    NotificationRead[]
}

model NotificationRead {
  id             String       @id @default(uuid())
  userId         String
  notificationId String
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
}
